@model LightIdiomas.ViewModels.ClientesViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Cadastrar Cliente";
}

<section class="p-6">
  <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-md p-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-semibold">Cadastro de Cliente</h1>
      <a href="javascript:history.back()" class="text-sm text-slate-600 hover:text-slate-800">Voltar</a>
    </div>

    <form asp-controller="CadastrarCliente" asp-action="CadastrarCliente" method="post" novalidate>
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="mb-4 text-sm text-red-600"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label asp-for="Nome_Cliente" class="block text-sm font-medium text-slate-700">Nome *</label>
          <input asp-for="Nome_Cliente" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:ring-brand-blue focus:border-brand-blue" required />
          <span asp-validation-for="Nome_Cliente" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="Nacionalidade" class="block text-sm font-medium text-slate-700">Nacionalidade *</label>
          <input asp-for="Nacionalidade" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required />
          <span asp-validation-for="Nacionalidade" class="text-sm text-red-600"></span>
        </div>

        <div class="md:col-span-2">
          <label asp-for="Endereco" class="block text-sm font-medium text-slate-700">Endereço *</label>
          <input asp-for="Endereco" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required />
          <span asp-validation-for="Endereco" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="RG" class="block text-sm font-medium text-slate-700">RG *</label>
          <input asp-for="RG" id="RG" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required />
          <span asp-validation-for="RG" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="CPF" class="block text-sm font-medium text-slate-700">CPF *</label>
          <input asp-for="CPF" id="CPF" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required />
          <span asp-validation-for="CPF" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="Profissao" class="block text-sm font-medium text-slate-700">Profissão *</label>
          <input asp-for="Profissao" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required />
          <span asp-validation-for="Profissao" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="Email" class="block text-sm font-medium text-slate-700">Email *</label>
          <input asp-for="Email" type="email" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required />
          <span asp-validation-for="Email" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="Telefone" class="block text-sm font-medium text-slate-700">Telefone *</label>
          <input asp-for="Telefone" type="tel" id="telefone" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required />
          <span asp-validation-for="Telefone" class="text-sm text-red-600"></span>
        </div>

        <div class="flex items-center gap-2 mt-2">
          <input asp-for="Whatsapp" type="checkbox" class="h-4 w-4 rounded border-slate-300" />
          <label asp-for="Whatsapp" class="text-sm text-slate-700">Whatsapp</label>
        </div>

        <div>
          <label asp-for="EstadoId" class="block text-sm font-medium text-slate-700">Estado *</label>
          <select asp-for="EstadoId" asp-items="Model.Estados" id="estadoSelect" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required>
            <option value="">Selecione o Estado</option>
          </select>
          <span asp-validation-for="EstadoId" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="CidadeId" class="block text-sm font-medium text-slate-700">Cidade *</label>
          <select asp-for="CidadeId" asp-items="Model.Cidades" id="cidadeSelect" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required>
            <option value="">Selecione a Cidade</option>
          </select>
          <span asp-validation-for="CidadeId" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="DataNascimento" class="block text-sm font-medium text-slate-700">Data de Nascimento *</label>
          <input asp-for="DataNascimento" type="date" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required />
          <span asp-validation-for="DataNascimento" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="Genero" class="block text-sm font-medium text-slate-700">Gênero *</label>
          <select asp-for="Genero" asp-items="Model.Generos" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required>
            <option value="">Selecione o gênero</option>
          </select>
          <span asp-validation-for="Genero" class="text-sm text-red-600"></span>
        </div>

        <div>
          <label asp-for="TurmaId" class="block text-sm font-medium text-slate-700">Turma</label>
          <select asp-for="TurmaId" asp-items="Model.Turmas" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm">
            <option value="">Selecione a Turma</option>
          </select>
        </div>

        <div>
          <label asp-for="NivelIngles" class="block text-sm font-medium text-slate-700">Nível de Inglês *</label>
          <select asp-for="NivelIngles" asp-items="@Html.GetEnumSelectList<LightIdiomas.Entities.NivelIngles>()" class="mt-1 block w-full rounded-md border-slate-300 shadow-sm" required>
            <option value="">Selecione o Nível do Inglês</option>
          </select>
          <span asp-validation-for="NivelIngles" class="text-sm text-red-600"></span>
        </div>
      </div>

      <div class="mt-6 flex items-center gap-3">
        <button type="submit" class="px-5 py-2 rounded bg-brand-blue text-white hover:bg-brand-blue/90">Cadastrar</button>
        <button type="reset" class="px-4 py-2 rounded border border-slate-300 text-slate-700 hover:bg-slate-50">Limpar</button>
      </div>
    </form>
  </div>
</section>

@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="~/js/CadastrarCliente.js" asp-append-version="true"></script>
}



