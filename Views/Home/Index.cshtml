@{
    ViewData["Title"] = "Home Page";
}

<form asp-controller="Home" asp-action="CadastrarCliente" method="post">
    <button type="submit" class="btn btn-primary">Cadastrar Cliente</button>
</form>

@if (TempData["Sucesso"] != null)
{
    <script>
        exibirAlerta('@TempData["Sucesso"]', "success");
    </script>
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/CadastrarCliente.js" asp-append-version="true"></script>
