@model List<LightIdiomas.Entities.Clientes>

<div class="container-fluid">
  <div class="row mb-4">
    <div class="col-12 col-sm-6 col-md-4 mb-3">
      <div class="card text-white bg-primary h-100">
        <div class="card-body">
          <h5 class="card-title">Total de Alunos</h5>
          <p class="card-text fs-2">@Model.Count()</p>
        </div>
      </div>
    </div>

    <div class="col-12 col-sm-6 col-md-4 mb-3">
      <div class="card text-white bg-success h-100">
        <div class="card-body">
          <h5 class="card-title">Alunos com Whatsapp</h5>
          <p class="card-text fs-2">@Model.Count(c => c.Whatsapp)</p>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-4 mb-3">
      <div class="card text-white bg-light h-100">
        <div class="card-body">
          <h5 class="card-title">Alunos por Nacionalidade</h5>
          <ul class="list-unstyled mb-0">
            @foreach (var grp in Model.GroupBy(c => c.Nacionalidade).OrderBy(g => g.Key))
            {
              <li>@grp.Key: @grp.Count()</li>
            }
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-start mb-3">
    <a href="/CadastrarCliente/CadastrarCliente" class="btn btn-success" aria-label="Cadastrar novo aluno">
      Cadastrar Novo Aluno
    </a>
  </div>

    <div class="d-flex justify-content-start mb-3">
        <a href="/CadastrarTurma/CadastrarTurma" class="btn btn-success" aria-label="Cadastrar nova turma">
            Cadastrar Nova Turma
        </a>
    </div>

  <div class="table-responsive">
    <table class="table table-bordered table-hover table-striped">
      <thead class="table-primary">
        <tr>
          <th scope="col">Nome</th>
          <th scope="col">Nacionalidade</th>
          <th scope="col">Endereço</th>
          <th scope="col">RG</th>
          <th scope="col">CPF</th>
          <th scope="col">Profissão</th>
          <th scope="col">Email</th>
          <th scope="col">Telefone</th>
          <th scope="col">Whatsapp</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var cliente in Model)
        {
          <tr>
            <td>@cliente.Nm_Cliente</td>
            <td>@cliente.Nacionalidade</td>
            <td>@cliente.Endereco</td>
            <td>@cliente.RG</td>
            <td>@cliente.CPF</td>
            <td>@cliente.Profissao</td>
            <td>@cliente.Email</td>
            <td>@cliente.Telefone</td>
            <td>@(cliente.Whatsapp ? "Sim" : "Não")</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
