@model IEnumerable<LightIdiomas.Entities.Clientes>?

@{
    ViewData["Title"] = "Light Idiomas - Dashboard";
    var students = Model ?? Enumerable.Empty<LightIdiomas.Entities.Clientes>();
    var totalAlunos = students.Count();
}
<!DOCTYPE html>

<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <!-- BEGIN: Tailwind Configuration -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
          theme: {
            extend: {
              colors: {
                brand: {
                  navy: '#1e293b',
                  blue: '#3b82f6',
                  light: '#f8fafc',
                  accent: '#f59e0b'
                }
              }
            }
          }
        }
    </script>
    <!-- END: Tailwind Configuration -->
    <style data-purpose="custom-scrollbars">
        /* Custom scrollbar for better aesthetics */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
    <style data-purpose="layout-tweaks">
        .sidebar-transition { transition: all 0.3s ease-in-out; }
        .table-row-hover:hover { background-color: rgba(59, 130, 246, 0.05); }
    </style>
</head>

<body class="bg-brand-light text-slate-800 font-sans antialiased">
    <div class="flex h-screen overflow-hidden">
        <!-- BEGIN: Sidebar Navigation -->
        <aside class="hidden md:flex flex-col w-64 bg-brand-navy text-white sidebar-transition" data-purpose="main-sidebar">
            <div class="p-6 flex items-center gap-3">
                <div class="w-10 h-10 bg-brand-accent rounded-lg flex items-center justify-center font-bold text-brand-navy text-xl">L</div>
                <span class="text-xl font-bold tracking-tight">Light Idiomas</span>
            </div>
            <nav class="flex-1 px-4 py-4 space-y-1">
                <a class="flex items-center gap-3 px-4 py-3 bg-brand-blue rounded-lg text-white" href="#">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    Dashboard
                </a>
                <a class="flex items-center gap-3 px-4 py-3 hover:bg-slate-700 rounded-lg transition-colors" href="#">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    Alunos
                </a>
                <a class="flex items-center gap-3 px-4 py-3 hover:bg-slate-700 rounded-lg transition-colors" href="#">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    Turmas
                </a>
                <a class="flex items-center gap-3 px-4 py-3 hover:bg-slate-700 rounded-lg transition-colors" href="#">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    Relatórios
                </a>
            </nav>
            <div class="p-4 border-t border-slate-700">
                <a class="flex items-center gap-3 px-4 py-3 hover:bg-slate-700 rounded-lg transition-colors" href="#">
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    Configurações
                </a>
            </div>
        </aside>
        <!-- END: Sidebar Navigation -->
        <!-- BEGIN: Main Content Area -->
        <main class="flex-1 flex flex-col overflow-hidden">
            <!-- BEGIN: Header -->
            <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shrink-0" data-purpose="main-header">
                <div class="flex items-center gap-4 flex-1">
                    <div class="relative w-full max-w-md">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                        </span>
                        <input class="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent" placeholder="Buscar alunos ou turmas..." type="text" />
                    </div>
                </div>
                <div class="flex items-center gap-6">
                    <button class="relative text-slate-400 hover:text-brand-blue">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                        <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-red-500 ring-2 ring-white"></span>
                    </button>
                    <div class="flex items-center gap-3 pl-6 border-l border-slate-200">
                        <div class="text-right">
                            <p class="text-sm font-semibold">Admin User</p>
                            <p class="text-xs text-slate-500">Administrador</p>
                        </div>
                        <img alt="Avatar" class="h-9 w-9 rounded-full bg-slate-200 object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA3S5g2z8s2pwhplqHJUDsYLvbZJfkagM9B9oUXAGgObKB27xjrshRpkdisPFF7ddGNKZka3-FNF8lGtm1ZPPsuOEr1GxGO5fL35cind9dD-w-OLhyOJN4IFwAXEc97FPW9tNT8YWwVqvrulDbcHYRsM-JU3dW8QfjWLAzyArHmV2xCJdOd3ogNspdmJOTrXISY1QjXj7HZWbaJKYyf8y_HikvzCgIlCUQmIyq2Y0wio72xf3AsKEoom3YHZak3po-LeWnuU7ylF7g" />
                    </div>
                </div>
            </header>
            <!-- END: Header -->
            <!-- BEGIN: Content Scroll Area -->
            <div class="flex-1 overflow-y-auto p-8">
                <!-- BEGIN: Page Title & Welcome -->
                <div class="mb-8">
                    <h1 class="text-2xl font-bold text-slate-800">Bem-vindo à Light Idiomas</h1>
                    <p class="text-slate-500">Confira o status atual da sua escola hoje.</p>
                </div>
                <!-- END: Page Title & Welcome -->
                <!-- BEGIN: Dashboard Summary Cards -->
                <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8" data-purpose="kpi-cards">
                    <!-- Total de Alunos Card -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-slate-500 mb-1">Total de Alunos</p>
                            <h3 class="text-3xl font-bold text-slate-800">@totalAlunos</h3>
                            <p class="text-xs text-green-600 mt-2 font-medium flex items-center gap-1">
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd"></path></svg>
                                +12% este mês
                            </p>
                        </div>
                        <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-brand-blue">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                        </div>
                    </div>
                    <!-- WhatsApp Ativo Card -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-slate-500 mb-1">WhatsApp Ativo</p>
                            <h3 class="text-3xl font-bold text-slate-800">Conectado</h3>
                            <p class="text-xs text-slate-400 mt-2">API Status: <span class="text-green-500 font-bold">OK</span></p>
                        </div>
                        <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
                            <svg class="w-7 h-7" fill="currentColor" viewbox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
                        </div>
                    </div>
                    <!-- Distribuição Card -->
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-slate-500 mb-1">Cursos Ativos</p>
                            <h3 class="text-3xl font-bold text-slate-800">14</h3>
                            <p class="text-xs text-brand-blue mt-2 underline cursor-pointer">Ver detalhes</p>
                        </div>
                        <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center text-brand-accent">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path><path d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                        </div>
                    </div>
                </section>
                <!-- END: Dashboard Summary Cards -->
                <!-- BEGIN: Student List Table -->
                <section class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-purpose="student-management">
                    <div class="p-6 border-b border-slate-100 flex items-center justify-between">
                        <div>
                            <h2 class="text-lg font-bold text-slate-800">Lista de Alunos</h2>
                            <p class="text-sm text-slate-500">Gerencie todos os estudantes matriculados e seus status.</p>
                        </div>
                        <a class="px-4 py-2 bg-brand-navy text-white text-sm font-semibold rounded-lg hover:bg-slate-800 transition-all flex items-center gap-2" asp-controller="CadastrarCliente" asp-action="CadastrarCliente">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 6v6m0 0v6m0-6h6m-6 0H6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                            Novo Aluno
                        </a>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-xs font-semibold text-slate-400 uppercase tracking-wider bg-slate-50">
                                    <th class="px-6 py-4">Nome do Aluno</th>
                                    <th class="px-6 py-4">Curso / Nível</th>
                                    <th class="px-6 py-4">Status Pagamento</th>
                                    <th class="px-6 py-4">Última Atividade</th>
                                    <th class="px-6 py-4 text-right">Ações</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                @foreach (var aluno in students)
{
    
    var nome = aluno.Nm_Cliente ?? string.Empty;
    var initials = nome
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Where(s => s.Length > 0)
        .Select(s => s[0])
        .Take(2)
        .ToArray();
    var initialsText = initials.Length > 0 ? string.Concat(initials) : "U";
    var courseOrLevel = aluno.Turma?.Nome ?? aluno.NivelIngles.ToString();
    

    <tr class="table-row-hover transition-colors">
        <td class="px-6 py-4">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center font-bold text-xs text-brand-blue">
                    @initialsText
                </div>
                <div>
                    <div class="text-sm font-semibold text-slate-800">@aluno.Nm_Cliente</div>
                    <div class="text-xs text-slate-500">@aluno.Email</div>
                </div>
            </div>
        </td>
        <td class="px-6 py-4">
            <span class="text-sm text-slate-600 font-medium">@courseOrLevel</span>
        </td>
        <td class="px-6 py-4">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                Regular
            </span>
        </td>
        <td class="px-6 py-4">
            <span class="text-sm text-slate-500">—</span>
        </td>
        <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
                <a asp-controller="CadastrarCliente" asp-action="CadastrarCliente" asp-route-id="@aluno.Id" class="p-2 text-slate-400 hover:text-brand-blue rounded-lg hover:bg-blue-50 transition-colors" title="Editar">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                </a>
                <form asp-controller="CadastrarCliente" asp-action="Delete" asp-route-id="@aluno.Id" method="post" onsubmit="return confirm('Confirma exclusão?');" class="inline">
                    <button type="submit" class="p-2 text-slate-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-colors" title="Remover">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </button>
                </form>
            </div>
        </td>
    </tr>
}
                                @if (!students.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="px-6 py-8 text-center text-slate-500">Nenhum aluno encontrado.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between text-sm text-slate-500">
                        <span>Exibindo @students.Count() alunos</span>
                        <div class="flex gap-2">
                            <button class="px-3 py-1 border border-slate-200 rounded hover:bg-slate-50 disabled:opacity-50">Anterior</button>
                            <button class="px-3 py-1 border border-slate-200 rounded hover:bg-slate-50">Próximo</button>
                        </div>
                    </div>
                </section>
                <!-- END: Student List Table -->
            </div>
            <!-- END: Content Scroll Area -->
        </main>
        <!-- END: Main Content Area -->
    </div>
</body>

</html>