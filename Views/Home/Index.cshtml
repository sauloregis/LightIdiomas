@model IEnumerable<LightIdiomas.Entities.Clientes>?

@{
    ViewData["Title"] = "Light Idiomas - Dashboard";
    var students = Model ?? Enumerable.Empty<LightIdiomas.Entities.Clientes>();
    var totalAlunos = students.Count();
}

<header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shrink-0" data-purpose="main-header">
    <div class="flex items-center gap-4 flex-1">
        <div class="relative w-full max-w-md">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3" aria-hidden="true">
                <!-- ícone de busca -->
                <svg class="w-4 h-4 text-slate-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" role="img" aria-label="Buscar">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M16.65 16.65A7.5 7.5 0 1116.65 2a7.5 7.5 0 010 14.65z" />
                </svg>
            </span>
            <input class="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent" placeholder="Buscar alunos ou turmas..." type="text" aria-label="Buscar alunos ou turmas" />
        </div>
    </div>
    <div class="flex items-center gap-6">
        <div class="flex items-center gap-3 pl-6 border-l border-slate-200">
            <div class="text-right">
                <p class="text-sm font-semibold">Admin User</p>
                <p class="text-xs text-slate-500">Administrador</p>
            </div>
            <div class="h-9 w-9 rounded-full bg-slate-100 flex items-center justify-center font-bold text-xs text-brand-blue" title="Admin User" aria-hidden="false">AU</div>
        </div>
    </div>
</header>

<div class="flex-1 overflow-y-auto p-8">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-800">Bem-vindo à Light Idiomas</h1>
        <p class="text-slate-500">Confira o status atual da sua escola hoje.</p>
    </div>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8" data-purpose="kpi-cards">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-slate-500 mb-1">Total de Alunos</p>
                <h3 class="text-3xl font-bold text-slate-800">@totalAlunos</h3>
            </div>
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-brand-blue" aria-hidden="true" title="Alunos">
                <!-- ícone de pessoas / alunos -->
                <svg class="w-6 h-6 text-brand-blue" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-1a4 4 0 00-4-4h-1M9 20H4v-1a4 4 0 014-4h1m0-6a3 3 0 11-6 0 3 3 0 016 0zm8 0a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
            </div>
        </div>
        <!-- outros cards... -->
    </section>

    <section class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" data-purpose="student-management">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h2 class="text-lg font-bold text-slate-800">Lista de Alunos</h2>
                <p class="text-sm text-slate-500">Gerencie todos os estudantes matriculados e seus status.</p>
            </div>
            <a class="px-4 py-2 bg-brand-navy text-white text-sm font-semibold rounded-lg hover:bg-slate-800 transition-all flex items-center gap-2" asp-controller="CadastrarCliente" asp-action="CadastrarCliente" role="button" aria-label="Novo Aluno">
                <!-- ícone + -->
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Novo Aluno
            </a>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-xs font-semibold text-slate-400 uppercase tracking-wider bg-slate-50">
                        <th class="px-6 py-4">Nome do Aluno</th>
                        <th class="px-6 py-4">Curso / Nível</th>
                        <th class="px-6 py-4">Status Pagamento</th>
                        <th class="px-6 py-4">Última Atividade</th>
                        <th class="px-6 py-4 text-right">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
@foreach (var aluno in students)
{
    var nome = aluno.Nm_Cliente ?? string.Empty;
    var initials = nome
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Where(s => s.Length > 0)
        .Select(s => s[0])
        .Take(2)
        .ToArray();
    var initialsText = initials.Length > 0 ? string.Concat(initials) : "U";
    var courseOrLevel = aluno.Turma?.Nome ?? aluno.NivelIngles.ToString();

    <tr class="table-row-hover transition-colors">
        <td class="px-6 py-4">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center font-bold text-xs text-brand-blue">
                    @initialsText
                </div>
                <div>
                    <div class="text-sm font-semibold text-slate-800">@aluno.Nm_Cliente</div>
                    <div class="text-xs text-slate-500">@aluno.Email</div>
                </div>
            </div>
        </td>
        <td class="px-6 py-4">
            <span class="text-sm text-slate-600 font-medium">@courseOrLevel</span>
        </td>
        <td class="px-6 py-4">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Regular</span>
        </td>
        <td class="px-6 py-4"><span class="text-sm text-slate-500">—</span></td>
        <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
                <a asp-controller="CadastrarCliente" asp-action="CadastrarCliente" asp-route-id="@aluno.Id" class="p-2 text-slate-400 hover:text-brand-blue rounded-lg hover:bg-blue-50 transition-colors" title="Editar" aria-label="Editar @aluno.Nm_Cliente">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                </a>
                <form asp-controller="CadastrarCliente" asp-action="Delete" asp-route-id="@aluno.Id" method="post" onsubmit="return confirm('Confirma exclusão?');" class="inline" aria-label="Remover @aluno.Nm_Cliente">
                    <button type="submit" class="p-2 text-slate-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-colors" title="Remover">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </button>
                </form>
            </div>
        </td>
    </tr>
}
@if (!students.Any())
{
    <tr>
        <td colspan="5" class="px-6 py-8 text-center text-slate-500">Nenhum aluno encontrado.</td>
    </tr>
}
                </tbody>
            </table>
        </div>

        <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between text-sm text-slate-500">
            <span>Exibindo @students.Count() alunos</span>
            <div class="flex gap-2">
                <button class="px-3 py-1 border border-slate-200 rounded hover:bg-slate-50 disabled:opacity-50">Anterior</button>
                <button class="px-3 py-1 border border-slate-200 rounded hover:bg-slate-50">Próximo</button>
            </div>
        </div>
    </section>
</div>