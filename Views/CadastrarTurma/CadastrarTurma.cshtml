@using LightIdiomas.ViewModels
@model TurmaViewModel

<form asp-action="CadastrarTurma" method="post">
    <div class="form-group">
        <label asp-for="Nome"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Dia">Dia da Semana</label>
        <select asp-for="Dia" class="form-control"
                asp-items="Html.GetEnumSelectList<DayOfWeek>()">
            <option value="">Selecione o Dia</option>
        </select>
        <span asp-validation-for="Dia" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Horario"></label>
        <input asp-for="Horario" type="time" class="form-control" />
        <span asp-validation-for="Horario" class="text-danger"></span>
    </div>

    @* <div class="form-group">
        <label asp-for="Nivel"></label>
        <select asp-for="Nivel" asp-items="Model.Nivel" class="form-control"></select>
    </div> *@

    <div class="form-group">
        <label asp-for="Status"></label>
        <select asp-for="Status" asp-items="Model.Statuses" class="form-control"></select>
    </div>

    <div class="form-group">
        <label asp-for="Tipo"></label>
        <select asp-for="Tipo" asp-items="Model.Tipos" class="form-control"></select>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
</form>

