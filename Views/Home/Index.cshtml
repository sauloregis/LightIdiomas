@model List<LightIdiomas.Entities.Clientes>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Dashboard - LightIdiomas</title>
<style>
  body {
    margin: 0;
    font-family: Arial, sans-serif;
    display: flex;
    height: 100vh;
  }
  /* Menu lateral */
  nav.sidebar {
    width: 220px;
    background-color: #2c3e50;
    color: white;
    display: flex;
    flex-direction: column;
    padding: 20px;
  }
  nav.sidebar h2 {
    margin: 0 0 20px;
  }
  nav.sidebar a {
    color: white;
    text-decoration: none;
    margin: 8px 0;
    font-weight: bold;
    cursor: pointer;
  }
  nav.sidebar a:hover {
    text-decoration: underline;
  }
  /* Conteúdo principal */
  main.content {
    flex: 1;
    padding: 20px;
    background: #ecf0f1;
    overflow-y: auto;
  }
  /* Dashboard */
  .dashboard {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
  }
  .card {
    background: white;
    border-radius: 6px;
    padding: 20px;
    flex: 1;
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.1);
  }
  .card h3 {
    margin: 0 0 10px;
  }
  /* Tabela */
  table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.1);
  }
  th, td {
    padding: 12px 15px;
    text-align: left;
    border-bottom: 1px solid #ddd;
  }
  th {
    background-color: #3498db;
    color: white;
  }
  tr:hover {
    background-color: #f1f1f1;
  }
  /* Botão Cadastrar */
  button#btnCadastrar {
    background-color: #27ae60;
    color: white;
    padding: 12px 20px;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    cursor: pointer;
    margin-bottom: 20px;
  }
  button#btnCadastrar:hover {
    background-color: #219150;
  }
</style>
</head>
<body>

<nav class="sidebar">
  <h2>LightIdiomas</h2>
  <a href="#">Dashboard</a>
  <a href="#">Alunos</a>
  <a href="#">Cursos</a>
  <a href="#">Configurações</a>
</nav>

<main class="content">
  <div class="dashboard">
    <div class="card">
      <h3>Total de Alunos</h3>
      <p id="totalAlunos">0</p>
    </div>
    <div class="card">
      <h3>Alunos com Whatsapp</h3>
      <p id="alunosWhatsapp">0</p>
    </div>
    <div class="card">
      <h3>Alunos por Nacionalidade</h3>
      <ul id="alunosPorNacionalidade"></ul>
    </div>
  </div>

    <!-- Botão Cadastrar -->
    <a href="/CadastrarCliente/CadastrarCliente"
      class="mb-6 inline-block bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-lg transition-colors">
      Cadastrar Novo Aluno
    </a>

    <!-- Tabela -->
    <div class="overflow-x-auto bg-white rounded-lg shadow">
      <table class="min-w-full table-auto border-collapse">
        <thead class="bg-blue-600 text-white">
          <tr>
            <th class="px-4 py-3 text-left">Nome</th>
            <th class="px-4 py-3 text-left">Nacionalidade</th>
            <th class="px-4 py-3 text-left">Endereço</th>
            <th class="px-4 py-3 text-left">RG</th>
            <th class="px-4 py-3 text-left">CPF</th>
            <th class="px-4 py-3 text-left">Profissão</th>
            <th class="px-4 py-3 text-left">Email</th>
            <th class="px-4 py-3 text-left">Telefone</th>
            <th class="px-4 py-3 text-left">Whatsapp</th>
          </tr>
        </thead>
        <tbody id="tabelaAlunosBody" class="divide-y divide-gray-200">
          @foreach (var cliente in Model)
          {
            <tr>
              <td class="px-4 py-3">@cliente.Nm_Cliente</td>
              <td class="px-4 py-3">@cliente.Nacionalidade</td>
              <td class="px-4 py-3">@cliente.Endereco</td>
              <td class="px-4 py-3">@cliente.RG</td>
              <td class="px-4 py-3">@cliente.CPF</td>
              <td class="px-4 py-3">@cliente.Profissao</td>
              <td class="px-4 py-3">@cliente.Email</td>
              <td class="px-4 py-3">@cliente.Telefone</td>
              <td class="px-4 py-3">@(cliente.Whatsapp ? "Sim" : "Não")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>

  </main>

<script src="index.js" type="module"></script>
</body>
</html>
